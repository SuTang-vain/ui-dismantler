{# lib.css.j2 — 参数化组件库样式模板
   从 manifest.json 生成 sg-* 前缀的参数化 CSS。
   变量：manifest, lib_name, prefix(=sg), theme_tokens, views, responsive
#}
/*!
 * {{ lib_name }}.css  v1.0.0
 * 由 html-to-component-lib skill 从 {{ manifest.meta.source | basename }} 自动生成
 * 主题定制：在 .{{ prefix }}-frame 上覆盖 --{{ prefix }}-* 变量
 */

/* ============================================================
 * 1. 主题令牌
 * ============================================================ */
:root,
.{{ prefix }}-frame {
{% for t in theme_tokens %}
  --{{ prefix }}-{{ t.name }}: {{ t.value }};
{% endfor %}
{% if not theme_tokens | selectattr('name','equalto','primary') | list %}
  --{{ prefix }}-primary: #6487FA;
{% endif %}
{% if not theme_tokens | selectattr('name','equalto','accent') | list %}
  --{{ prefix }}-accent: #E94F76;
{% endif %}
{% if not theme_tokens | selectattr('name','equalto','ink') | list %}
  --{{ prefix }}-ink: #1E1F24;
{% endif %}
{% if not theme_tokens | selectattr('name','equalto','muted') | list %}
  --{{ prefix }}-muted: #848691;
{% endif %}
{% if not theme_tokens | selectattr('name','equalto','line') | list %}
  --{{ prefix }}-line: #ECEDF1;
{% endif %}
{% if not theme_tokens | selectattr('name','equalto','paper') | list %}
  --{{ prefix }}-paper: #FFFFFF;
{% endif %}
  /* 次要色（固定语义，避免硬编码） */
  --{{ prefix }}-white: #FFFFFF;
  --{{ prefix }}-sub-bg: #FAFAFB;
  --{{ prefix }}-decl: #90929a;
  /* 画布尺寸 */
  --{{ prefix }}-frame-w: {{ canvas_pc[0] or 788 }}px;
  --{{ prefix }}-frame-h: {{ canvas_pc[1] or 492 }}px;
  --{{ prefix }}-frame-radius: 14px;
  /* 圆角 */
  --{{ prefix }}-r-card: 10px;
  --{{ prefix }}-r-row: 8px;
  --{{ prefix }}-r-pill: 999px;
  /* 动效 */
  --{{ prefix }}-ease: cubic-bezier(.25, .46, .45, .94);
  --{{ prefix }}-dur-fast: .15s;
  --{{ prefix }}-dur-mid: .25s;
  --{{ prefix }}-dur-slow: .55s;
}

/* ============================================================
 * 2. 基础与画布
 * ============================================================ */
.{{ prefix }}-frame *,
.{{ prefix }}-frame *::before,
.{{ prefix }}-frame *::after { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

.{{ prefix }}-frame {
  width: var(--{{ prefix }}-frame-w);
  height: var(--{{ prefix }}-frame-h);
  position: relative;
  overflow: hidden;
  background: var(--{{ prefix }}-paper);
  border: 1px solid rgba(30, 31, 36, 0.06);
  border-radius: var(--{{ prefix }}-frame-radius);
  box-shadow: 0 18px 48px rgba(23, 24, 28, 0.10);
  display: grid;
  grid-template-rows: 36px 1fr;
  color: var(--{{ prefix }}-ink);
  font-family: Inter, "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
  font-size: 14px;
  line-height: 1.58;
}
.{{ prefix }}-frame button { font: inherit; color: inherit; cursor: pointer; }

/* ============================================================
 * 3. Tab Bar
 * ============================================================ */
.{{ prefix }}-tab-bar {
  display: grid;
  grid-template-columns: repeat({{ tabs | length }}, 1fr);
  align-items: end;
  padding: 0 18px;
  border-bottom: 1px solid var(--{{ prefix }}-line);
  background: var(--{{ prefix }}-paper);
}
.{{ prefix }}-tab {
  position: relative;
  height: 36px;
  border: 0;
  background: transparent;
  color: var(--{{ prefix }}-muted);
  font-size: 12.5px;
  font-weight: 600;
  text-align: center;
  border-bottom: 2px solid transparent;
  transition: color var(--{{ prefix }}-dur-fast) ease, border-color var(--{{ prefix }}-dur-fast) ease;
}
.{{ prefix }}-tab[aria-selected="true"] {
  color: var(--{{ prefix }}-ink);
  border-bottom-color: var(--{{ prefix }}-primary);
}
.{{ prefix }}-tab small { margin-left: 6px; color: var(--{{ prefix }}-subtle, #B7B9C1); font-weight: 500; }
.{{ prefix }}-tab[aria-selected="true"] small { color: var(--{{ prefix }}-muted); }
.{{ prefix }}-tab.{{ prefix }}-tab-more { color: var(--{{ prefix }}-muted); }
.{{ prefix }}-tab.{{ prefix }}-tab-more[aria-selected="true"] {
  color: var(--{{ prefix }}-ink);
  border-bottom-color: var(--{{ prefix }}-accent);
}
.{{ prefix }}-tab.{{ prefix }}-tab-more[aria-selected="false"]::after {
  content: "↗"; margin-left: 6px; font-size: 10px; color: var(--{{ prefix }}-subtle, #B7B9C1);
}

/* ============================================================
 * 4. View Stack + Section Head
 * ============================================================ */
.{{ prefix }}-view-stack { position: relative; min-height: 0; overflow: hidden; }
.{{ prefix }}-view { position: absolute; inset: 0; display: none; padding: 14px 18px; }
.{{ prefix }}-view.active { display: grid; }
.{{ prefix }}-section-head { display: flex; align-items: baseline; justify-content: space-between; }
.{{ prefix }}-section-head strong { font-size: 13px; font-weight: 700; }
.{{ prefix }}-section-head span { color: var(--{{ prefix }}-muted); font-size: 11px; }
/* generic 视图（无结构化识别时的兜底容器） */
.{{ prefix }}-generic-view { grid-template-rows: auto 1fr; gap: 10px; }
.{{ prefix }}-generic-body { overflow: auto; color: var(--{{ prefix }}-ink); font-size: 13px; line-height: 1.6; }
.{{ prefix }}-generic-body .{{ prefix }}-subtitle { color: var(--{{ prefix }}-muted); font-size: 11px; margin: 0 0 8px; }

/* ============================================================
 * 5. 通用轮播控件
 * ============================================================ */
.{{ prefix }}-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px; border-radius: 50%;
  border: 1px solid var(--{{ prefix }}-primary);
  background: var(--{{ prefix }}-primary); color: var({{ prefix }}-white);
  font-size: 16px; line-height: 1;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 3; padding: 0;
  transition: all var(--{{ prefix }}-dur-fast) ease;
  backdrop-filter: blur(4px);
}
.{{ prefix }}-arrow:hover {
  background: var({{ prefix }}-white); color: var(--{{ prefix }}-primary);
  border-color: var(--{{ prefix }}-primary);
  box-shadow: 0 2px 8px rgba(100, 135, 250, 0.25);
}
.{{ prefix }}-arrow.is-hidden { display: none; }
.{{ prefix }}-arrow.{{ prefix }}-prev { left: -14px; }
.{{ prefix }}-arrow.{{ prefix }}-next { right: -14px; }
.{{ prefix }}-dots { display: flex; justify-content: center; gap: 5px; padding-top: 8px; }
.{{ prefix }}-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--{{ prefix }}-line); border: none; padding: 0;
  cursor: pointer; transition: all var(--{{ prefix }}-dur-mid) ease;
}
.{{ prefix }}-dot.is-active { background: var(--{{ prefix }}-primary); width: 16px; border-radius: 3px; }

{% if has_member_grid %}
/* ============================================================
 * 6. 成员视图
 * ============================================================ */
.{{ prefix }}-members-view { grid-template-columns: 1.45fr 0.85fr; gap: 14px; align-content: stretch; align-items: stretch; }
.{{ prefix }}-member-stage { min-width: 0; display: grid; grid-template-rows: 1fr auto; min-height: 0; position: relative; }
.{{ prefix }}-member-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  grid-template-rows: repeat(2, minmax(0, 1fr));
  gap: 10px; min-height: 0; height: 100%;
}
.{{ prefix }}-member {
  min-width: 0; min-height: 0;
  border: 1px solid var(--{{ prefix }}-line);
  border-radius: var(--{{ prefix }}-r-card);
  background: var({{ prefix }}-sub-bg); overflow: hidden; text-align: left;
  transition: border-color var(--{{ prefix }}-dur-fast) ease, background var(--{{ prefix }}-dur-fast) ease, transform .12s ease;
  display: flex; flex-direction: column; padding: 0;
}
.{{ prefix }}-member:hover { border-color: var(--{{ prefix }}-subtle, #B7B9C1); }
.{{ prefix }}-member[aria-pressed="true"] { border-color: var(--{{ prefix }}-primary); background: var(--{{ prefix }}-soft, #F2F4FB); }
.{{ prefix }}-avatar {
  width: 100%; height: 100%; flex: 1;
  display: flex; align-items: stretch; justify-content: stretch;
  background: var(--{{ prefix }}-ink); color: var({{ prefix }}-white);
  font-size: 14px; font-weight: 700;
  overflow: hidden; position: relative; margin: 0; padding: 0;
}
.{{ prefix }}-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center center; display: block; }
.{{ prefix }}-avatar img.is-loaded + .{{ prefix }}-avatar-fallback,
.{{ prefix }}-avatar img.is-error + .{{ prefix }}-avatar-fallback { display: none; }
.{{ prefix }}-avatar img.is-error { display: none; }
.{{ prefix }}-avatar .{{ prefix }}-avatar-fallback {
  position: absolute; inset: 0; display: grid; place-items: center;
  font-size: 14px; font-weight: 700; letter-spacing: 0.02em;
  background: linear-gradient(135deg, rgba(42,43,51,1) 0%, var(--{{ prefix }}-ink) 100%);
  color: var({{ prefix }}-white);
}
.{{ prefix }}-avatar .{{ prefix }}-photo-source {
  position: absolute; top: 4px; right: 4px;
  padding: 1px 4px; border-radius: 4px;
  background: rgba(30,31,36,0.55); color: var({{ prefix }}-white);
  font-size: 8px; font-weight: 600; letter-spacing: 0.02em; pointer-events: none;
}
.{{ prefix }}-member-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px 10px 6px;
  background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
  display: flex; flex-direction: column; gap: 2px;
}
.{{ prefix }}-member-name { display: block; font-size: 12px; font-weight: 700; color: var({{ prefix }}-white); text-shadow: 0 1px 2px rgba(0,0,0,0.5); }
.{{ prefix }}-member-role { display: block; font-size: 10px; color: rgba(255,255,255,0.85); }
.{{ prefix }}-member-state {
  display: inline-block; margin-top: 3px; padding: 1px 5px;
  border-radius: var(--{{ prefix }}-r-pill);
  background: rgba(255,255,255,0.2); color: var({{ prefix }}-white); font-size: 9px; font-weight: 700;
}

/* 详情面板 */
.{{ prefix }}-detail-panel {
  min-width: 0; border: 1px solid var(--{{ prefix }}-line);
  border-radius: var(--{{ prefix }}-r-card); padding: 12px;
  background: linear-gradient(180deg, var(--{{ prefix }}-paper) 0%, var(--{{ prefix }}-soft, #F2F4FB) 100%);
  display: grid; grid-template-rows: auto auto auto 1fr auto;
  gap: 8px; align-content: start;
}
.{{ prefix }}-detail-kicker {
  color: var(--{{ prefix }}-primary); font-size: 10.5px; font-weight: 800;
  letter-spacing: 0.05em; text-transform: uppercase;
}
.{{ prefix }}-detail-panel h2 { margin: 0; font-size: 18px; font-weight: 700; letter-spacing: -0.01em; }
.{{ prefix }}-detail-panel .{{ prefix }}-subtitle { margin: -4px 0 0; color: var(--{{ prefix }}-muted); font-size: 11.5px; }
.{{ prefix }}-relation-list { display: grid; gap: 6px; align-content: start; }
.{{ prefix }}-relation-row {
  display: grid; grid-template-columns: 64px 1fr; align-items: center; gap: 8px;
  padding: 6px 8px; border-radius: var(--{{ prefix }}-r-row);
  background: rgba(255,255,255,0.7); border: 1px solid var(--{{ prefix }}-line);
}
.{{ prefix }}-relation-row .{{ prefix }}-rel-label { font-size: 10px; color: var(--{{ prefix }}-muted); font-weight: 700; }
.{{ prefix }}-relation-row .{{ prefix }}-rel-value { font-size: 11.5px; color: var(--{{ prefix }}-ink); font-weight: 600; }
.{{ prefix }}-source-note { color: var({{ prefix }}-decl); font-size: 10px; border-top: 1px dashed var(--{{ prefix }}-line); padding-top: 6px; }
{% endif %}

{% if has_timeline %}
/* ============================================================
 * 7. 时间线视图
 * ============================================================ */
.{{ prefix }}-timeline-view { grid-template-rows: auto 1fr; gap: 8px; }
.{{ prefix }}-tl-scroll-wrap { position: relative; overflow: hidden; min-height: 0; display: flex; flex-direction: column; }
.{{ prefix }}-tl-track {
  display: flex; gap: 10px; overflow-x: auto;
  scroll-snap-type: x mandatory; flex: 1; align-items: stretch;
  scroll-behavior: smooth; padding-top: 6px;
  -webkit-overflow-scrolling: touch; scrollbar-width: none;
}
.{{ prefix }}-tl-track::-webkit-scrollbar { display: none; }
.{{ prefix }}-tl-track::before {
  content: ""; position: absolute; top: 14px; left: 6%; right: 6%;
  height: 1px; background: var(--{{ prefix }}-line); pointer-events: none;
}
.{{ prefix }}-t-item {
  position: relative; padding: 12px;
  border: 1px solid var(--{{ prefix }}-line);
  border-radius: var(--{{ prefix }}-r-card); background: var({{ prefix }}-sub-bg);
  display: flex; flex-direction: column;
  flex: 0 0 calc((100% - 20px) / {{ timeline_per_page_pc }});
  scroll-snap-align: start;
  min-width: calc((100% - 20px) / {{ timeline_per_page_pc }});
}
.{{ prefix }}-t-item::before {
  content: ""; position: absolute; top: -6px; left: 14px;
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--{{ prefix }}-primary); box-shadow: 0 0 0 3px var({{ prefix }}-white);
}
.{{ prefix }}-t-item time { display: block; color: var(--{{ prefix }}-primary); font-size: 11px; font-weight: 800; letter-spacing: 0.02em; margin-bottom: 4px; }
.{{ prefix }}-t-item b { display: block; font-size: 13px; font-weight: 700; margin-bottom: 4px; }
.{{ prefix }}-t-item p { margin: 0; color: var(--{{ prefix }}-muted); font-size: 11px; line-height: 1.5; }
.{{ prefix }}-t-item.is-selected { border-color: var(--{{ prefix }}-primary); background: var(--{{ prefix }}-soft, #F2F4FB); }
.{{ prefix }}-t-item .{{ prefix }}-t-img { width: 100%; flex: 1 1 auto; min-height: 0; object-fit: cover; border-radius: 6px; margin-bottom: 6px; display: block; }
.{{ prefix }}-t-item .{{ prefix }}-t-info { flex: 0 0 auto; display: flex; flex-direction: column; }
.{{ prefix }}-tl-prev-pc, .{{ prefix }}-tl-next-pc { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; }
.{{ prefix }}-tl-prev-pc { left: 0; }
.{{ prefix }}-tl-next-pc { right: 0; }
.{{ prefix }}-tl-prev-mobile, .{{ prefix }}-tl-next-mobile { display: none; }
.{{ prefix }}-tl-controls { display: none; }
.{{ prefix }}-tl-dots { display: none; }
{% endif %}

{% if has_carousel_3d %}
/* ============================================================
 * 8. 作品视图：3D 中心聚焦轮播
 * ============================================================ */
.{{ prefix }}-works-view { grid-template-rows: auto 1fr auto; gap: 6px; }
.{{ prefix }}-ws-scroll-wrap { position: relative; overflow: hidden; min-height: 0; display: flex; flex-direction: column; }
.{{ prefix }}-works-carousel {
  display: flex; align-items: center; justify-content: center;
  flex: 1; perspective: {{ carousel_perspective }}px; overflow: hidden; min-height: 0;
}
.{{ prefix }}-work-item {
  position: absolute; flex-shrink: 0;
  border-radius: var(--{{ prefix }}-r-card); overflow: hidden;
  background: var({{ prefix }}-sub-bg); cursor: pointer;
  transition: all var(--{{ prefix }}-dur-slow) var(--{{ prefix }}-ease);
  display: flex; flex-direction: column;
  width: 120px; height: 70%; opacity: 0; transform: scale(.6); z-index: 0; pointer-events: none;
}
{% for pos in carousel_positions %}
.{{ prefix }}-work-item.{{ pos.cls }} {
{% if pos.width %}  width: {{ pos.width }}px;
{% endif %}{% if pos.height %}  height: {{ pos.height }}px;
{% endif %}  opacity: {{ pos.opacity }};
  transform: scale({% if pos.cls == 'is-center' %}1{% else %}.82{% endif %}) {% if pos.translateX %}translateX({{ pos.translateX }}px){% endif %} {% if pos.translateZ %}translateZ({{ pos.translateZ }}px){% endif %};
{% if pos.blur %}  filter: blur({{ pos.blur }}px);
{% endif %}{% if pos.zIndex %}  z-index: {{ pos.zIndex }};
{% endif %}{% if pos.cls == 'is-center' %}  max-height: 100%; aspect-ratio: 1; pointer-events: auto; box-shadow: 0 10px 36px rgba(0, 0, 0, 0.18);
{% elif 'side' in pos.cls %}  height: 78%; pointer-events: auto;
{% elif 'far' in pos.cls %}  height: 62%; pointer-events: none;
{% endif %}}
{% endfor %}
.{{ prefix }}-work-item .{{ prefix }}-w-img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: var(--{{ prefix }}-r-card); }
.{{ prefix }}-work-item .{{ prefix }}-work-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.82));
  color: var({{ prefix }}-white); padding: 28px 14px 12px;
  transform: translateY(100%); opacity: 0;
  transition: all .35s ease; border-radius: 0 0 var(--{{ prefix }}-r-card) var(--{{ prefix }}-r-card);
  pointer-events: none;
}
.{{ prefix }}-work-item.is-center:hover .{{ prefix }}-work-info,
.{{ prefix }}-work-item.is-center.is-info-visible .{{ prefix }}-work-info { transform: translateY(0); opacity: 1; }
.{{ prefix }}-work-item .{{ prefix }}-work-year { display: block; color: var(--{{ prefix }}-accent); font-size: 10px; font-weight: 800; margin-bottom: 3px; }
.{{ prefix }}-work-item b { display: block; font-size: 13px; font-weight: 700; color: var({{ prefix }}-white); margin-bottom: 4px; }
.{{ prefix }}-work-item p { margin: 0; color: rgba(255, 255, 255, 0.82); font-size: 10px; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.{{ prefix }}-ws-prev, .{{ prefix }}-ws-next {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px; border-radius: 50%;
  border: 1px solid var(--{{ prefix }}-primary); background: var(--{{ prefix }}-primary); color: var({{ prefix }}-white);
  font-size: 16px; line-height: 1; display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 5; padding: 0; transition: all var(--{{ prefix }}-dur-fast) ease; backdrop-filter: blur(4px);
}
.{{ prefix }}-ws-prev:hover, .{{ prefix }}-ws-next:hover { background: var({{ prefix }}-white); color: var(--{{ prefix }}-primary); border-color: var(--{{ prefix }}-primary); box-shadow: 0 2px 8px rgba(100, 135, 250, 0.25); }
.{{ prefix }}-ws-prev { left: 4px; }
.{{ prefix }}-ws-next { right: 4px; }
.{{ prefix }}-ws-dots { display: flex; justify-content: center; align-items: center; gap: 6px; padding: 4px 0 2px; flex-shrink: 0; }
.{{ prefix }}-ws-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--{{ prefix }}-line); border: none; padding: 0; cursor: pointer; transition: all var(--{{ prefix }}-dur-mid) ease; }
.{{ prefix }}-ws-dot.is-active { background: var(--{{ prefix }}-primary); width: 20px; border-radius: 4px; }

/* 创作故事引导 + 面板 */
.{{ prefix }}-ws-story-cta {
  display: inline-flex; align-items: center; gap: 7px; align-self: center;
  padding: 6px 14px 6px 11px; border: 1px solid var(--{{ prefix }}-line);
  border-radius: var(--{{ prefix }}-r-pill); background: var(--{{ prefix }}-paper);
  color: var(--{{ prefix }}-muted); font-size: 11px; font-weight: 600; letter-spacing: .02em;
  cursor: pointer; transition: border-color .18s ease, background .18s ease, color .18s ease; flex-shrink: 0;
}
.{{ prefix }}-ws-story-cta::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--{{ prefix }}-accent); flex-shrink: 0; transition: background .18s ease; }
.{{ prefix }}-ws-story-cta:hover { border-color: var(--{{ prefix }}-primary); background: var(--{{ prefix }}-soft, #F2F4FB); color: var(--{{ prefix }}-ink); }
.{{ prefix }}-ws-story-cta:hover::before { background: var(--{{ prefix }}-primary); }
.{{ prefix }}-ws-story-cta:active { transform: translateY(1px); }
.{{ prefix }}-work-story-panel {
  position: absolute; inset: 0; z-index: 10; background: var(--{{ prefix }}-paper);
  border-radius: var(--{{ prefix }}-r-card); display: none; flex-direction: column;
  padding: 14px 16px; overflow: hidden; box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
}
.{{ prefix }}-work-story-panel.open { display: flex; animation: {{ prefix }}-slide-in .35s var(--{{ prefix }}-ease); }
@keyframes {{ prefix }}-slide-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.{{ prefix }}-ws-story-close {
  position: absolute; top: 8px; right: 10px; width: 24px; height: 24px;
  border: none; border-radius: 50%; background: var(--{{ prefix }}-line); color: var(--{{ prefix }}-muted);
  font-size: 16px; line-height: 1; cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all var(--{{ prefix }}-dur-fast) ease; z-index: 2;
}
.{{ prefix }}-ws-story-close:hover { background: var(--{{ prefix }}-accent); color: var({{ prefix }}-white); }
.{{ prefix }}-ws-story-body { display: flex; gap: 14px; flex: 1; overflow: hidden; align-items: stretch; min-height: 0; }
.{{ prefix }}-ws-story-cover { flex: 6 1 0; min-width: 0; height: auto; border-radius: var(--{{ prefix }}-r-row); object-fit: cover; background: var({{ prefix }}-sub-bg); }
.{{ prefix }}-ws-story-content { flex: 4 1 0; overflow-y: auto; min-width: 0; padding-right: 4px; display: flex; flex-direction: column; }
.{{ prefix }}-ws-story-content .{{ prefix }}-ws-year { color: var(--{{ prefix }}-accent); font-size: 13px; font-weight: 800; letter-spacing: .3px; }
.{{ prefix }}-ws-story-content h3 { font-size: 20px; font-weight: 800; color: var(--{{ prefix }}-ink); margin: 4px 0 10px; line-height: 1.25; }
.{{ prefix }}-ws-story-divider { height: 1px; background: var(--{{ prefix }}-line); margin: 4px 0 10px; }
.{{ prefix }}-ws-story-label { display: inline-block; color: var(--{{ prefix }}-primary); font-size: 11px; font-weight: 800; letter-spacing: 1px; margin-bottom: 8px; text-transform: uppercase; }
.{{ prefix }}-ws-story-text { font-size: 14px; line-height: 1.8; color: var(--{{ prefix }}-muted); margin: 0; text-align: justify; }
{% endif %}

/* ============================================================
 * 9. Modal 体系
 * ============================================================ */
.{{ prefix }}-modal-overlay {
  position: absolute; inset: 0; background: rgba(30, 31, 36, 0.45);
  display: none; align-items: center; justify-content: center; padding: 20px; z-index: 5;
}
.{{ prefix }}-modal-overlay.open { display: flex; }
.{{ prefix }}-modal-card {
  position: relative; width: 100%; max-width: 620px; max-height: 100%;
  background: var(--{{ prefix }}-paper); border-radius: 12px;
  padding: 14px 16px 12px; display: grid;
  grid-template-rows: auto auto minmax(0,1fr) auto; gap: 8px;
  box-shadow: 0 24px 60px rgba(0,0,0,0.25); min-height: 0;
}
.{{ prefix }}-modal-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
.{{ prefix }}-modal-card h3 { margin: 0; font-size: 15px; font-weight: 700; letter-spacing: -0.005em; }
.{{ prefix }}-modal-card .{{ prefix }}-modal-sub { margin: 0; color: var(--{{ prefix }}-muted); font-size: 11px; line-height: 1.4; }
.{{ prefix }}-modal-body { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; align-content: start; font-size: 11.5px; color: var(--{{ prefix }}-ink); line-height: 1.45; overflow: hidden; }
.{{ prefix }}-modal-body .{{ prefix }}-m-row { display: grid; grid-template-rows: auto 1fr; gap: 3px; padding: 7px 9px; border: 1px solid var(--{{ prefix }}-line); border-radius: 7px; background: var({{ prefix }}-sub-bg); min-width: 0; }
.{{ prefix }}-modal-body .{{ prefix }}-m-row.full { grid-column: 1 / -1; }
.{{ prefix }}-modal-body .{{ prefix }}-m-row small { color: var(--{{ prefix }}-muted); font-size: 10px; font-weight: 700; letter-spacing: 0.02em; }
.{{ prefix }}-modal-body .{{ prefix }}-m-row span { display: block; font-size: 11.5px; font-weight: 600; color: var(--{{ prefix }}-ink); word-break: break-word; }
.{{ prefix }}-modal-foot { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.{{ prefix }}-modal-foot .{{ prefix }}-modal-decl { color: var({{ prefix }}-decl); font-size: 10px; }
.{{ prefix }}-modal-close { border: 1px solid var(--{{ prefix }}-line); background: var({{ prefix }}-white); color: var(--{{ prefix }}-ink); border-radius: 7px; padding: 5px 12px; font-size: 11.5px; font-weight: 700; }
.{{ prefix }}-modal-x-btn {
  position: absolute; top: 8px; right: 8px; width: 26px; height: 26px;
  border-radius: 50%; border: none; background: rgba(0,0,0,0.45); color: var({{ prefix }}-white);
  font-size: 18px; line-height: 1; display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 10; padding: 0; transition: background var(--{{ prefix }}-dur-fast) ease;
}
.{{ prefix }}-modal-x-btn:hover { background: rgba(0,0,0,0.65); }
.{{ prefix }}-member-detail-modal .{{ prefix }}-modal-body { display: grid; grid-template-columns: 1fr; gap: 6px; }
.{{ prefix }}-tl-modal-card { max-width: 320px; width: 100%; padding: 0; overflow: hidden; display: flex; flex-direction: column; position: relative; background: var({{ prefix }}-white); border-radius: 12px; }
.{{ prefix }}-tl-modal-card .{{ prefix }}-modal-body { padding: 0; margin: 0; display: flex; flex-direction: column; }
.{{ prefix }}-tl-modal-img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; }
.{{ prefix }}-tl-modal-text { padding: 14px 16px 18px; }
.{{ prefix }}-tl-modal-text h3 { margin: 0 0 8px; font-size: 15px; font-weight: 700; color: var(--{{ prefix }}-ink); }
.{{ prefix }}-tl-modal-text p { margin: 0; font-size: 12px; line-height: 1.7; color: var(--{{ prefix }}-muted); }

{% if has_responsive_wise %}
/* ============================================================
 * 10. WISE / 移动端 (≤500px)
 * ============================================================ */
@media (max-width: 500px) {
  .{{ prefix }}-frame { width: {{ canvas_wise[0] or 380 }}px; height: {{ canvas_wise[1] or 456 }}px; grid-template-rows: 32px 1fr; border-radius: 12px; }
  .{{ prefix }}-tab-bar { padding: 0 14px; }
  .{{ prefix }}-tab { height: 32px; font-size: 11.5px; }
  .{{ prefix }}-view { padding: 10px 14px; }
{% if has_member_grid %}
  .{{ prefix }}-members-view { grid-template-columns: 1fr; }
  .{{ prefix }}-member-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .{{ prefix }}-arrow { width: 22px; height: 22px; font-size: 13px; }
  .{{ prefix }}-arrow.{{ prefix }}-prev { left: -11px; }
  .{{ prefix }}-arrow.{{ prefix }}-next { right: -11px; }
  .{{ prefix }}-dots { padding-top: 6px; }
  .{{ prefix }}-detail-panel { display: none; }
{% endif %}
{% if has_timeline %}
  .{{ prefix }}-timeline-view { grid-template-rows: auto 1fr auto; min-height: 0; }
  .{{ prefix }}-t-item { flex: 0 0 calc((100% - 10px) / {{ timeline_per_page_mobile }}); min-width: calc((100% - 10px) / {{ timeline_per_page_mobile }}); display: flex; flex-direction: column; height: 100%; }
  .{{ prefix }}-tl-prev-pc, .{{ prefix }}-tl-next-pc { display: none; }
  .{{ prefix }}-tl-prev-mobile, .{{ prefix }}-tl-next-mobile { display: flex; position: static; transform: none; width: 22px; height: 22px; font-size: 13px; flex-shrink: 0; }
  .{{ prefix }}-tl-controls { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 6px 4px 2px; flex-shrink: 0; }
  .{{ prefix }}-tl-dots { display: flex; justify-content: center; gap: 5px; padding: 0; flex: 1; }
  .{{ prefix }}-tl-dots .{{ prefix }}-tl-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--{{ prefix }}-line); border: none; padding: 0; cursor: pointer; transition: all var(--{{ prefix }}-dur-mid) ease; }
  .{{ prefix }}-tl-dots .{{ prefix }}-tl-dot.is-active { background: var(--{{ prefix }}-primary); width: 16px; border-radius: 3px; }
{% endif %}
{% if has_carousel_3d %}
  .{{ prefix }}-works-view { grid-template-rows: auto 1fr auto; }
  .{{ prefix }}-works-carousel { align-items: center; }
  .{{ prefix }}-work-item.is-center { width: 55%; height: auto; aspect-ratio: 1; max-height: 100%; }
  .{{ prefix }}-work-item.is-prev-side { width: 19%; height: auto; aspect-ratio: 1; transform: scale(.85) translateX(-105%) translateZ(-15px); }
  .{{ prefix }}-work-item.is-next-side { width: 19%; height: auto; aspect-ratio: 1; transform: scale(.85) translateX(105%) translateZ(-15px); }
  .{{ prefix }}-work-item.is-prev-far { width: 13%; height: auto; aspect-ratio: 1; opacity: 0.22; filter: blur(2.5px); transform: scale(.72) translateX(-185%) translateZ(-30px); }
  .{{ prefix }}-work-item.is-next-far { width: 13%; height: auto; aspect-ratio: 1; opacity: 0.22; filter: blur(2.5px); transform: scale(.72) translateX(185%) translateZ(-30px); }
  .{{ prefix }}-ws-prev, .{{ prefix }}-ws-next { width: 22px; height: 22px; font-size: 13px; }
  .{{ prefix }}-ws-dot { width: 6px; height: 6px; }
  .{{ prefix }}-ws-dot.is-active { width: 16px; }
  .{{ prefix }}-ws-story-cta { padding: 5px 12px 5px 10px; font-size: 10px; }
  .{{ prefix }}-work-story-panel { padding: 10px 12px; }
  .{{ prefix }}-ws-story-body { flex-direction: column; gap: 10px; }
  .{{ prefix }}-ws-story-cover { flex: 6 1 0; width: 100%; min-height: 0; height: auto; }
  .{{ prefix }}-ws-story-content { flex: 4 1 0; min-height: 0; overflow-y: auto; }
  .{{ prefix }}-ws-story-content h3 { font-size: 17px; margin: 2px 0 6px; }
  .{{ prefix }}-ws-story-text { font-size: 13px; line-height: 1.7; }
{% endif %}
}
{% endif %}

{% if has_responsive_extreme %}
/* ============================================================
 * 11. 极端小尺寸 (≤320px 或 ≤380h)
 * ============================================================ */
@media (max-width: 320px), (max-height: 380px) {
  .{{ prefix }}-frame { width: 100%; height: 100%; min-width: 280px; min-height: 340px; grid-template-rows: 36px 1fr; border-radius: 8px; }
  .{{ prefix }}-tab-bar { padding: 0 8px; }
  .{{ prefix }}-tab { height: 36px; font-size: 10px; padding: 0 4px; }
  .{{ prefix }}-tab small { display: none; }
  .{{ prefix }}-view { padding: 8px; }
{% if has_member_grid %}
  .{{ prefix }}-members-view { grid-template-columns: 1fr; }
  .{{ prefix }}-member-stage { display: flex; flex-direction: column; min-height: 0; }
  .{{ prefix }}-members-view .{{ prefix }}-section-head { display: none; }
  .{{ prefix }}-member-grid { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); gap: 6px; flex: 1; }
  .{{ prefix }}-arrow { width: 18px; height: 18px; font-size: 10px; }
  .{{ prefix }}-arrow.{{ prefix }}-prev { left: -9px; }
  .{{ prefix }}-arrow.{{ prefix }}-next { right: -9px; }
  .{{ prefix }}-dots { padding-top: 4px; }
  .{{ prefix }}-dots .{{ prefix }}-dot { width: 5px; height: 5px; }
  .{{ prefix }}-dots .{{ prefix }}-dot.is-active { width: 12px; }
  .{{ prefix }}-member { border-radius: 6px; min-height: 0; padding: 0; }
  .{{ prefix }}-avatar { border-radius: 6px; width: 100%; height: 100%; min-height: 0; }
  .{{ prefix }}-member-info { padding: 16px 6px 4px; }
  .{{ prefix }}-member-name { font-size: 10px; }
  .{{ prefix }}-member-role { font-size: 8px; }
  .{{ prefix }}-member-state { font-size: 7px; padding: 1px 3px; }
  .{{ prefix }}-photo-source { font-size: 6px; padding: 1px 2px; }
  .{{ prefix }}-detail-panel { display: none; }
{% endif %}
{% if has_timeline %}
  .{{ prefix }}-timeline-view { gap: 4px; grid-template-rows: auto 1fr auto; min-height: 0; }
  .{{ prefix }}-timeline-view .{{ prefix }}-section-head { display: flex; }
  .{{ prefix }}-timeline-view .{{ prefix }}-section-head span { font-size: 8px; }
  .{{ prefix }}-timeline-view .{{ prefix }}-section-head strong { font-size: 11px; }
  .{{ prefix }}-t-item { padding: 0; border-radius: 6px; min-height: 0; overflow: hidden; flex: 0 0 calc((100% - 6px) / {{ timeline_per_page_mobile }}); min-width: calc((100% - 6px) / {{ timeline_per_page_mobile }}); display: flex; flex-direction: column; height: 100%; }
  .{{ prefix }}-t-item .{{ prefix }}-t-img { display: block; width: 100%; flex: 1 1 auto; min-height: 0; aspect-ratio: auto; object-fit: cover; border-radius: 0; margin: 0; flex-shrink: 1; }
  .{{ prefix }}-t-item .{{ prefix }}-t-info { display: block; padding: 3px 6px 4px; flex: 0 0 auto; }
  .{{ prefix }}-t-item .{{ prefix }}-t-info time { display: block; color: var(--{{ prefix }}-primary); font-size: 9px; font-weight: 800; margin-bottom: 1px; }
  .{{ prefix }}-t-item::before { display: none; }
  .{{ prefix }}-t-item .{{ prefix }}-t-info b { display: block; font-size: 10px; font-weight: 700; color: var(--{{ prefix }}-ink); margin-bottom: 2px; }
  .{{ prefix }}-t-item .{{ prefix }}-t-info p { margin: 0; font-size: 8px; line-height: 1.4; color: var(--{{ prefix }}-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .{{ prefix }}-tl-dots { gap: 4px; }
  .{{ prefix }}-tl-dots .{{ prefix }}-tl-dot { width: 5px; height: 5px; }
  .{{ prefix }}-tl-dots .{{ prefix }}-tl-dot.is-active { width: 14px; border-radius: 3px; }
  .{{ prefix }}-tl-prev-mobile, .{{ prefix }}-tl-next-mobile { display: flex; position: static; transform: none; width: 18px; height: 18px; font-size: 10px; z-index: 4; flex-shrink: 0; }
  .{{ prefix }}-tl-prev-pc, .{{ prefix }}-tl-next-pc { display: none; }
  .{{ prefix }}-tl-controls { display: flex; align-items: center; justify-content: space-between; gap: 6px; padding: 4px 0 0; flex-shrink: 0; }
{% endif %}
{% if has_carousel_3d %}
  .{{ prefix }}-works-view { gap: 4px; }
  .{{ prefix }}-work-item.is-center { width: 60%; height: auto; aspect-ratio: 1; max-height: 100%; }
  .{{ prefix }}-work-item.is-prev-side { width: 15%; height: auto; aspect-ratio: 1; transform: scale(.8) translateX(-80%) translateZ(-12px); }
  .{{ prefix }}-work-item.is-next-side { width: 15%; height: auto; aspect-ratio: 1; transform: scale(.8) translateX(80%) translateZ(-12px); }
  .{{ prefix }}-ws-prev, .{{ prefix }}-ws-next { width: 18px; height: 18px; font-size: 10px; }
  .{{ prefix }}-ws-dot { width: 5px; height: 5px; }
  .{{ prefix }}-ws-dot.is-active { width: 14px; }
  .{{ prefix }}-ws-story-cta { padding: 4px 10px 4px 8px; font-size: 9px; }
  .{{ prefix }}-ws-story-cta::before { width: 5px; height: 5px; }
  .{{ prefix }}-work-story-panel { padding: 8px 10px; }
  .{{ prefix }}-ws-story-body { gap: 8px; }
  .{{ prefix }}-ws-story-content h3 { font-size: 14px; margin: 2px 0 4px; }
  .{{ prefix }}-ws-story-text { font-size: 11px; line-height: 1.6; }
  .{{ prefix }}-ws-story-label { font-size: 10px; margin-bottom: 4px; }
{% endif %}
  .{{ prefix }}-modal-card { max-width: 260px; padding: 10px 12px; border-radius: 8px; }
  .{{ prefix }}-modal-card h3 { font-size: 13px; }
  .{{ prefix }}-modal-card .{{ prefix }}-modal-sub { font-size: 9px; }
  .{{ prefix }}-modal-body { grid-template-columns: 1fr; gap: 4px; font-size: 10px; }
  .{{ prefix }}-modal-body .{{ prefix }}-m-row { padding: 5px 6px; border-radius: 5px; }
  .{{ prefix }}-modal-body .{{ prefix }}-m-row small { font-size: 8px; }
  .{{ prefix }}-modal-body .{{ prefix }}-m-row span { font-size: 10px; }
  .{{ prefix }}-modal-foot .{{ prefix }}-modal-decl { font-size: 8px; }
  .{{ prefix }}-modal-close { padding: 4px 8px; font-size: 10px; border-radius: 5px; }
  .{{ prefix }}-member-detail-modal { max-width: 240px; }
}
{% endif %}
